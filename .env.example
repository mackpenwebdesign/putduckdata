# ============================================================
# DATABASE  ← REQUIRED
# ============================================================
DATABASE_URL=


# ============================================================
# AUTHENTICATION  ← REQUIRED
# ============================================================
JWT_SECRET=
JWT_EXPIRY=7d


# ============================================================
# PAYSTACK PAYMENT GATEWAY  ← REQUIRED
# ============================================================
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Webhook secret — set in Paystack dashboard → Webhooks → your endpoint URL
PAYSTACK_WEBHOOK_SECRET=https://putduckdata.com/api/paystack-webhook


# ============================================================
# DATA PROVIDER  ← REQUIRED
# ============================================================
ONEPAPI_API_KEY=


# ============================================================
# FRONTEND URL  ← REQUIRED
# ============================================================
FRONTEND_URL=https://putduckdata.com

# ============================================================
# FRONTEND — VITE VARS  ← REQUIRED
# ============================================================
VITE_API_URL=/api

# Custom URL slug for the admin dashboard (obscures the admin route)
VITE_ADMIN_PATH=/pk-admin-control

# Local dev only — proxy target (where vercel dev / backend runs)
VITE_DEV_PROXY=http://localhost:8888


# ============================================================
# SECURITY  ← OPTIONAL  (defaults shown)
# ============================================================
RATE_LIMIT_MAX=60
MAX_LOGIN_ATTEMPTS=5


# ============================================================
# ENVIRONMENT  ← Do NOT set NODE_ENV on Vercel (Vercel sets it automatically)
# For local dev only: NODE_ENV=development
# ============================================================
